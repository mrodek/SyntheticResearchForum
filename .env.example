# Synthetic Research Forum — environment variable reference
# Copy this file to .env and fill in real values. Never commit .env.

# ── LLM Provider (required) ───────────────────────────────────────────────────
# Supported values: anthropic, openai
SRF_LLM_PROVIDER=anthropic

# Model name for the configured provider
SRF_LLM_MODEL=claude-sonnet-4-6

# API key for the configured provider
SRF_LLM_API_KEY=your-api-key-here

# ── PromptLedger Observability (optional) ─────────────────────────────────────
# Both vars must be set together, or both omitted (graceful degradation).
PROMPTLEDGER_API_URL=https://your-promptledger-instance.up.railway.app
PROMPTLEDGER_API_KEY=your-promptledger-api-key

# ── Runtime Configuration ─────────────────────────────────────────────────────
# Workspace volume root — defaults to /data/workspace on Railway
SRF_WORKSPACE_ROOT=/data/workspace

# Log level: DEBUG, INFO, WARNING, ERROR — defaults to INFO
SRF_LOG_LEVEL=INFO
