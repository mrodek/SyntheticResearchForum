# Synthetic Research Forum — environment variable reference
# Copy this file to .env and fill in real values. Never commit .env.

# ── SRF Python Scripts ────────────────────────────────────────────────────────

# LLM Provider (required by srf_init.py and tracker=None fallback path)
# Supported values: anthropic, openai
SRF_LLM_PROVIDER=anthropic

# Model name for the configured provider
SRF_LLM_MODEL=claude-sonnet-4-6

# API key for the configured provider (used in tracker=None fallback only)
SRF_LLM_API_KEY=your-api-key-here

# ── PromptLedger Observability (optional) ─────────────────────────────────────
# Both vars must be set together, or both omitted (graceful degradation).
PROMPTLEDGER_API_URL=https://your-promptledger-instance.up.railway.app
PROMPTLEDGER_API_KEY=your-promptledger-project-key

# ── Runtime Tuning ────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR — defaults to INFO
SRF_LOG_LEVEL=INFO

# Workspace root for SRFConfig (Python runtime) — defaults to /data/workspace
# On Railway this should match OPENCLAW_WORKSPACE_DIR
SRF_WORKSPACE_ROOT=/data/workspace

# Minimum number of papers required to run a forum — defaults to 2
SRF_MIN_PAPERS=2

# arXiv API politeness delay between requests in seconds — defaults to 3
SRF_ARXIV_DELAY_SECONDS=3

# Maximum number of agents (Paper + Challenger) in a forum — defaults to 4
SRF_MIN_AGENTS=2

# Maximum LLM call retries during agent preparation — defaults to 3
SRF_MAX_PREP_RETRIES=3

# Max context tokens per agent debate turn — defaults to 200000
SRF_DEBATE_CONTEXT_TOKENS=200000

# ── OpenClaw Gateway ──────────────────────────────────────────────────────────
# One-time setup password for the OpenClaw /setup web wizard
SETUP_PASSWORD=choose-a-strong-password

# Port the OpenClaw HTTP server listens on — Railway sets this automatically
PORT=8080

# Path where OpenClaw stores its runtime state (auth tokens, config cache)
OPENCLAW_STATE_DIR=/data/openclaw

# Path to the SRF workspace volume — mounted at /data/workspace on Railway
OPENCLAW_WORKSPACE_DIR=/data/workspace

# Bearer token for authenticating API requests to the OpenClaw gateway
# Generate a random secret: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
